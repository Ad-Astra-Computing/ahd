{
  "type": "object",
  "properties": {
    "sampleId": {
      "type": "string",
      "minLength": 1
    },
    "cell": {
      "type": "string",
      "minLength": 1
    },
    "condition": {
      "type": "string",
      "enum": [
        "raw",
        "compiled"
      ]
    },
    "seed": {
      "type": "integer"
    },
    "requestId": {
      "type": "string"
    },
    "finishReason": {
      "type": "string"
    },
    "tokenUsage": {
      "type": "object",
      "properties": {
        "inputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "outputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "totalTokens": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "rawResponse": {
      "type": "string"
    },
    "extractedHtml": {
      "type": "string",
      "minLength": 1
    },
    "providerMeta": {
      "type": "object",
      "additionalProperties": {}
    }
  },
  "required": [
    "sampleId",
    "cell",
    "condition",
    "extractedHtml"
  ],
  "additionalProperties": false,
  "description": "Per-sample envelope (target shape). Captures provider response, token usage, request id and the extracted HTML. Stretch target; today samples ship as <id>.html + <id>.raw.txt without a structured envelope.",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ahd.adastra.computer/schema/sample-envelope.target.schema.json",
  "title": "AHD per-sample envelope (target shape)"
}
