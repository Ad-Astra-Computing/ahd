{
  "name": "@adastracomputing/ahd",
  "version": "0.7.2",
  "description": "Artificial Human Design — a brief compiler, linter and style-token library that forces LLMs out of design slop.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "ahd": "./bin/ahd.js",
    "ahd-mcp": "./bin/ahd-mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint:tokens": "npm run build -s && node bin/ahd.js validate-tokens"
  },
  "files": [
    "bin",
    "dist",
    "tokens",
    "docs/POSITIONING.md",
    "docs/ROADMAP.md",
    "docs/USAGE.md",
    "docs/SLOP_TAXONOMY.md",
    "docs/LINTER_SPEC.md",
    "docs/STYLE_TOKEN_SCHEMA.md",
    "docs/TESTING.md",
    "docs/WEBSITE.md",
    "docs/SERVING_TELLS.md",
    "docs/artwork/*.svg",
    "docs/artwork/README.md",
    "schema",
    "README.md",
    "LICENSE",
    "LICENSE-tokens",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ad-Astra-Computing/ahd"
  },
  "homepage": "https://ahd.adastra.computer",
  "dependencies": {
    "playwright-core": "^1.59.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
