{
  "name": "@adastra/ahd",
  "version": "0.1.0",
  "description": "Artificial Human Design — a brief compiler, linter and style-token library that forces LLMs out of design slop.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "bin": {
    "ahd": "./bin/ahd.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint:tokens": "node bin/ahd.js validate-tokens"
  },
  "files": [
    "bin",
    "dist",
    "tokens",
    "docs",
    "schema",
    "README.md"
  ],
  "dependencies": {
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
