# Copy this to `.env` (already gitignored) and fill in the values you have.
# Every key is optional; ahd only requires the providers you actually name in --models.

# Anthropic (Claude) — needed for claude-* specs
ANTHROPIC_API_KEY=

# OpenAI (GPT / o-series) — needed for gpt-* / o* specs
OPENAI_API_KEY=

# Google (Gemini) — needed for gemini-* specs
GEMINI_API_KEY=

# Cloudflare Workers AI — needed for cf:@cf/... specs (OSS models, free tier)
CF_API_TOKEN=
CF_ACCOUNT_ID=

# Cloudflare AI Gateway — OPTIONAL. When set, every claude-*, gpt-*, gemini-*
# spec routes through the gateway for caching / rate-limiting / spend tracking.
# Format: <account_id>/<gateway_id>. Or a full URL for a self-hosted gateway.
CF_AI_GATEWAY=
